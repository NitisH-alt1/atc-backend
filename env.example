# ── ATC Live Backend — Environment Configuration ─────────────────────────────
# Copy this to .env and fill in your credentials.
# None of these are required — the server falls back to anonymous sources.

# ── OpenSky Network (optional but recommended) ────────────────────────────────
# Free account at https://opensky-network.org/
# With credentials you get 5s resolution instead of 10s, higher rate limits.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── AeroDataBox via RapidAPI (optional) ──────────────────────────────────────
# Paid API at https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# Used for aircraft type, airline name enrichment from the frontend.
AERODATABOX_KEY=

# ── AviationStack (optional) ─────────────────────────────────────────────────
# Free tier at https://aviationstack.com/ — 100 req/month
AVIATIONSTACK_KEY=

# ── Server tuning ─────────────────────────────────────────────────────────────
# How often (seconds) to re-fetch from upstream.  Minimum 5 for anonymous OpenSky.
CACHE_TTL=8

# Maximum aircraft to keep in memory / return per request.
MAX_AIRCRAFT=5000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
